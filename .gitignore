*.o
*.a
*.so
*.dylib

# ── Runtime data — never commit ────────────────────────────────────────────
*.log
*.wav
*.txt
*.bin
*.gguf

# ── Local-only configuration ───────────────────────────────────────────────
.env
.env.local
*.local.*

