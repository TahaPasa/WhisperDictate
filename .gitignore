# ── whisper.cpp vendored copy: keep sources, ignore artefacts ──────────────
whisper.cpp/build/
whisper.cpp/.git
whisper.cpp/.github/
whisper.cpp/models/*.bin
whisper.cpp/models/*.mlmodelc/
whisper.cpp/models/ggml-*.bin
